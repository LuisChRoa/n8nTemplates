    {
      "parameters": {
        "jsCode": "function getCleanData()\n{\n  // Este código limpia el texto extraído para mejorar el embedding\n  let text = $input.first().json.guardrailsInput || \"\";\n  // 1. Eliminar espacios en blanco excesivos\n  text = text.replace(/[ \\t]+/g, ' ');\n  // 2. Corregir saltos de línea huérfanos\n  // Esto une líneas que terminan en letra/coma y mantiene los párrafos reales (\\n\\n).\n  text = text.replace(/([^\\n])\\n([^\\n])/g, '$1 $2');\n  // 3. Eliminar múltiples saltos de línea\n  text = text.replace(/\\n{3,}/g, '\\n\\n');\n  // 4. Limpiar caracteres especiales que no aportan semántica (opcional)\n  text = text.replace(/[•●■]/g, '-'); \n  return text.trim();\n}\n\n\n// Genera un GUID simple\nfunction generateGUID() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\nconst items = $input.all();\n\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    document_id: generateGUID(),\n    document_name: $('file_metadata_extractor').first().json.fileName ?? 'unknown',\n    document_data: getCleanData()\n  }, \n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
