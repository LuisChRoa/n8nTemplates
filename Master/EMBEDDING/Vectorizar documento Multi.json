    {
      "parameters": {
        "jsCode": "// ===== Utilidades ==================================================\n\n// Valida types permitidos\nfunction mimeTypePermitido(mimeType) {\n  return [\n    \"application/pdf\",\n    \"text/plain\"\n  ].includes(mimeType);\n}\n\n// Obtiene el tamaño en bytes\nfunction convertirTamanoABytes(sizeStr) {\n  const num = parseFloat(sizeStr);\n  let bytes = num;\n\n  if (sizeStr.includes('kB')) {\n    bytes = num * 1024;\n  } \n  else if (sizeStr.includes('MB')) {\n    bytes = num * 1024 * 1024;\n  } \n  else if (sizeStr.includes('GB')) {\n    bytes = num * 1024 * 1024 * 1024;\n  }\n\n  return bytes;\n}\n\n// ===== Lógica principal =========================================\n\nconst item = items[0];\n\nconst sizeStr = item.binary.data.fileSize;\nconst mimeType = item.binary.data.mimeType;\n\nconst fileSizeBytes = convertirTamanoABytes(sizeStr);\nconst TypeValido = mimeTypePermitido(mimeType);\n\n// Guardar resultados para usar en IF node\nitem.json.fileSizeBytes = fileSizeBytes;\nitem.json.fileName = item.binary.data.fileName;;\nitem.json.typePermitido = TypeValido;\nitem.json.document = item.binary.data;\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
